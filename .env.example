# =============================================
# Vercel 환경변수로 등록하세요 (Settings > Environment Variables)
# =============================================

# Upstash Redis (무료: https://upstash.com → Create Database → REST API)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxx

# 텔레그램 봇 인증 (아무 문자열로 설정, 봇과 동일하게)
BOT_SECRET=my-secret-key-here

# =============================================
# 로컬 봇 실행 시 필요 (bot/pump_bot.py)
# =============================================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-1001234567890   # 모니터링할 채널/그룹 ID
COINCOPY_URL=https://your-app.vercel.app
